{
    "kind": "collectionType",
    "collectionName": "orders",
    "info": {
        "singularName": "order",
        "pluralName": "orders",
        "displayName": "Order",
        "description": "Customer orders"
    },
    "options": {
        "draftAndPublish": false
    },
    "attributes": {
        "customer_name": {
            "type": "string",
            "required": true
        },
        "customer_email": {
            "type": "email",
            "required": true
        },
        "customer_phone": {
            "type": "string",
            "required": true
        },
        "shipping_address": {
            "type": "text",
            "required": true
        },
        "items": {
            "type": "json",
            "required": true
        },
        "subtotal_amount": {
            "type": "decimal",
            "required": true
        },
        "tax_amount": {
            "type": "decimal",
            "required": true
        },
        "shipping_amount": {
            "type": "decimal",
            "required": true
        },
        "total_amount": {
            "type": "decimal",
            "required": true
        },
        "razorpay_order_id": {
            "type": "string"
        },
        "razorpay_payment_id": {
            "type": "string"
        },
        "payment_status": {
            "type": "enumeration",
            "enum": [
                "pending",
                "paid",
                "failed"
            ],
            "default": "pending",
            "required": true
        }
    }
}
